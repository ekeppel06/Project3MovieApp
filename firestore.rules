rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Rooms ─────────────────────────────────────────────────────────────
    match /rooms/{roomId} {

      // Anyone authenticated can read rooms (needed to look up invite codes)
      allow read: if request.auth != null;

      // Any authenticated user can create a room,
      // as long as they add themselves as the first member
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberIds.hasAll([request.auth.uid]);

      // Only existing members can update the room (e.g. join/leave)
      allow update: if request.auth != null
        && resource.data.memberIds.hasAny([request.auth.uid]);

      // Only the room creator can delete the room
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      allow update: if request.auth != null
        && resource.data.memberIds.hasAny([request.auth.uid])
      // Prevent members from changing votingActive (host only)
    && (!request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['votingActive', 'votingEndedAt', 'memberIds', 'inviteCode']));

      // Separate rule for host-only fields
      allow update: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      // ── Movies sub-collection ──────────────────────────────────────────
      match /movies/{movieId} {

        // Any room member can read movies
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds.hasAny([request.auth.uid]);

        // Any room member can add a movie
        allow create: if request.auth != null
          && get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds.hasAny([request.auth.uid])
          && request.resource.data.addedBy == request.auth.uid;

        // Only the person who added it can delete it
        allow delete: if request.auth != null
          && resource.data.addedBy == request.auth.uid;

        
      }
    }
  }
}
